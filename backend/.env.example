# ──────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in values.
# ──────────────────────────────────────────

# MongoDB connection string
# Local:    mongodb://localhost:27017/egovernance
# Atlas:    mongodb+srv://user:pass@cluster.mongodb.net/egovernance
MONGO_URI=mongodb://localhost:27017/egovernance

# Server port
PORT=5000

# JWT secret for authentication (change in production!)
JWT_SECRET=change_this_to_a_random_secret_string

# Deployed contract addresses (update after deployment)
VOTING_CONTRACT_ADDRESS=0xYourVotingContractAddress
LAND_CONTRACT_ADDRESS=0xYourLandContractAddress
FUND_CONTRACT_ADDRESS=0xYourFundContractAddress
